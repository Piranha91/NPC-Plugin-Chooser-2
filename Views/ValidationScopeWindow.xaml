<Window x:Class="NPC_Plugin_Chooser_2.Views.ValidationScopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NPC_Plugin_Chooser_2.View_Models"
        xmlns:themes="clr-namespace:NPC_Plugin_Chooser_2.Themes"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:VM_ValidationScopeWindow}"
        Title="Validate Output — Choose NPCs"
        Height="560" Width="640"
        WindowStartupLocation="CenterOwner"
        MinHeight="400" MinWidth="480"
        Style="{StaticResource ThemedWindowStyle}">

    <i:Interaction.Behaviors>
        <themes:TitleBarThemingBehavior />
    </i:Interaction.Behaviors>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding SummaryText}" Margin="0,0,0,10" FontWeight="SemiBold"/>

        <RadioButton Grid.Row="1" GroupName="Scope"
                     Content="Validate ALL NPCs with selections"
                     IsChecked="{Binding ScopeAllSelected, Mode=TwoWay}"
                     Margin="0,0,0,4"/>
        <RadioButton Grid.Row="2" GroupName="Scope"
                     Content="Validate only the NPCs I pick below"
                     IsChecked="{Binding ScopeSubset, Mode=TwoWay}"
                     Margin="0,0,0,8"/>

        <!-- Search + bulk check controls -->
        <Grid Grid.Row="3" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"
                     ToolTip="Filter by NPC name, FormKey, or selected mod"/>
            <Button Grid.Column="1" Content="Check Visible" Command="{Binding CheckAllVisibleCommand}" Margin="6,0,0,0" Padding="8,2"/>
            <Button Grid.Column="2" Content="Uncheck Visible" Command="{Binding UncheckAllVisibleCommand}" Margin="6,0,0,0" Padding="8,2"/>
        </Grid>

        <Border Grid.Row="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <ListBox ItemsSource="{Binding FilteredItems}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Checked="NpcCheckBox_Checked" Margin="2">
                            <CheckBox.Content>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding FormKeyText}" Opacity="0.7" Margin="8,0,0,0"/>
                                    <TextBlock Text="  →  " Opacity="0.7"/>
                                    <TextBlock Text="{Binding SelectedMod}" Opacity="0.9"/>
                                </StackPanel>
                            </CheckBox.Content>
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Validate" Click="OkButton_Click" Width="100" Height="30" IsDefault="True"/>
            <Button Content="Cancel" Click="CancelButton_Click" Width="100" Height="30" Margin="10,0,0,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
