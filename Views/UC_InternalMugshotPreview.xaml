<UserControl x:Class="NPC_Plugin_Chooser_2.Views.UC_InternalMugshotPreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:NPC_Plugin_Chooser_2.View_Models"
             xmlns:glWpf="clr-namespace:OpenTK.Wpf;assembly=GLWpfControl"
             xmlns:cvrv="clr-namespace:CharacterViewer.Rendering.Views;assembly=CharacterViewer.Rendering"
             mc:Ignorable="d"
             d:DesignHeight="540" d:DesignWidth="600"
             d:DataContext="{d:DesignInstance Type=vm:VM_InternalMugshotPreview}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- Toolbar -->
            <RowDefinition Height="Auto"/>     <!-- Lighting panel (shared with SynthEBD) -->
            <RowDefinition Height="*"/>        <!-- Viewport -->
            <RowDefinition Height="Auto"/>     <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Toolbar — Load/Reload/Reset only meaningful in the Settings panel.
             The per-tile 3D preview popup hides the whole row via the UC's
             ShowSettingsControls property (set false from FullScreen3DPreviewView). -->
        <Border x:Name="SettingsToolbar" Grid.Row="0" Padding="6" BorderBrush="Gray" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="Load Selected NPC" Command="{Binding LoadSelectedNpcCommand}" Padding="6,2" Margin="0,0,6,0"/>
                <Button Content="Reload" Command="{Binding ReloadCommand}" Padding="6,2" Margin="0,0,12,0"/>

                <Button Content="Reset" Command="{Binding ResetCommand}" Padding="6,2" Margin="0,0,6,0"
                        ToolTip="Restore Internal-renderer settings to defaults."/>
            </StackPanel>
        </Border>

        <!-- Shared lighting panel (CharacterViewer.Rendering 2.2.0+):
             layout / color scheme presets, ambient + Key/Fill/Rim toggles,
             Show-Lights gizmo gate, and per-light editor (intensity / azimuth /
             elevation / color picker). Click an arrow gizmo in the viewport to
             open that light's editor — handler in code-behind. -->
        <cvrv:UC_CharacterViewerLightingPanel Grid.Row="1"
                                              DataContext="{Binding Viewer}"/>

        <!-- Viewport with yellow crop overlay -->
        <Grid Grid.Row="2" x:Name="ViewportRoot" ClipToBounds="True" Background="#222">
            <glWpf:GLWpfControl x:Name="GlControl" Render="GlControl_OnRender"/>

            <!-- Yellow crop rectangle: positioned by code-behind -->
            <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
                <Rectangle x:Name="CropRect"
                           Stroke="#FFFF00"
                           StrokeThickness="2"
                           StrokeDashArray="4 4"
                           Visibility="Collapsed"/>
            </Canvas>

            <!-- Loading dim -->
            <Border Background="#80000000"
                    Visibility="{Binding Viewer.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="Loading…" Foreground="White" FontSize="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Status -->
        <Border Grid.Row="3" Padding="6,4" BorderBrush="Gray" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" Opacity="0.8" TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</UserControl>
