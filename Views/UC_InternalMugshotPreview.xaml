<UserControl x:Class="NPC_Plugin_Chooser_2.Views.UC_InternalMugshotPreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:NPC_Plugin_Chooser_2.View_Models"
             xmlns:glWpf="clr-namespace:OpenTK.Wpf;assembly=GLWpfControl"
             xmlns:cvrv="clr-namespace:CharacterViewer.Rendering.Views;assembly=CharacterViewer.Rendering"
             mc:Ignorable="d"
             d:DesignHeight="540" d:DesignWidth="600"
             d:DataContext="{d:DesignInstance Type=vm:VM_InternalMugshotPreview}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- Toolbar -->
            <RowDefinition Height="Auto"/>     <!-- Lighting panel (shared with SynthEBD) -->
            <RowDefinition Height="Auto"/>     <!-- Render panel (shared with SynthEBD) -->
            <RowDefinition Height="*"/>        <!-- Viewport -->
            <RowDefinition Height="Auto"/>     <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Toolbar - "Load Selected NPC" only meaningful in the Settings
             panel. The per-tile 3D preview popup hides the whole row via the
             UC's ShowSettingsControls property (set false from
             FullScreen3DPreviewView). Reset Settings was hoisted to the
             host's panel header in 2.5.17 so it stays reachable when the
             preview UC itself is hidden; Reload was removed in 2.5.16 since
             render-pipeline edits in the render panel below now apply on
             the next frame and the wireframe-missing-texture toggle auto-
             fires a re-load via ReloadRequested. -->
        <Border x:Name="SettingsToolbar" Grid.Row="0" Padding="6" BorderBrush="Gray" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="Load Selected NPC" Command="{Binding LoadSelectedNpcCommand}" Padding="6,2" Margin="0,0,12,0"/>
            </StackPanel>
        </Border>

        <!-- Shared lighting panel (CharacterViewer.Rendering 2.2.0+):
             layout / color scheme presets, ambient + Key/Fill/Rim toggles,
             Show-Lights gizmo gate, and per-light editor (intensity / azimuth /
             elevation / color picker). Click an arrow gizmo in the viewport to
             open that light's editor - handler in code-behind. -->
        <cvrv:UC_CharacterViewerLightingPanel Grid.Row="1"
                                              DataContext="{Binding Viewer}"/>

        <!-- Shared render panel (CharacterViewer.Rendering 2.5.16+):
             tone-mapping, shadows, SSAO + tunables, eye catch-light, SSS
             strength, vignette radius / intensity, missing-texture wireframe
             fallback. Edits two-way-bind to VM_CharacterViewer; the existing
             WhenAnyValue subscriptions push to GlRenderer on the next frame.
             VM_InternalMugshotPreview's bridge mirrors edits back to
             _settings.InternalMugshot.* with throttled save. -->
        <cvrv:UC_CharacterViewerRenderPanel Grid.Row="2"
                                            DataContext="{Binding Viewer}"/>

        <!-- Viewport with yellow crop overlay -->
        <Grid Grid.Row="3" x:Name="ViewportRoot" ClipToBounds="True" Background="#222">
            <glWpf:GLWpfControl x:Name="GlControl" Render="GlControl_OnRender"/>

            <!-- Yellow crop rectangle: positioned by code-behind -->
            <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
                <Rectangle x:Name="CropRect"
                           Stroke="#FFFF00"
                           StrokeThickness="2"
                           StrokeDashArray="4 4"
                           Visibility="Collapsed"/>
            </Canvas>

            <!-- Loading dim -->
            <Border Background="#80000000"
                    Visibility="{Binding Viewer.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="Loading…" Foreground="White" FontSize="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Attire toggles (Include Default Outfit / Include headgear).
                 Overlaid on the viewport so they stay visible in both the
                 Settings live preview and the full-screen 3D popup. Bind to the
                 wrapper VM (the UC's DataContext); toggling persists to settings
                 and re-applies the mesh-override set via a reload. -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6" Orientation="Vertical">
                <Border x:Name="AttireTogglePanel"
                        Background="#A0000000" CornerRadius="4" Padding="8,6">
                    <StackPanel Orientation="Vertical">
                        <CheckBox Content="Include Default Outfit" Foreground="White"
                                  IsChecked="{Binding IncludeDefaultOutfit}"
                                  ToolTip="Render the NPC's default outfit. Body-covering armor hides the nude body."/>
                        <CheckBox Content="Include headgear" Foreground="White" Margin="0,4,0,0"
                                  IsChecked="{Binding IncludeHeadgear}"
                                  Visibility="{Binding IncludeDefaultOutfit, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  ToolTip="Render worn/outfit head gear (helmets/hoods/circlets). Hair is hidden under headgear."/>
                    </StackPanel>
                </Border>

                <!-- "Set Antler Head Parts" selector (per-tile 3D popup only; hidden
                     when the NPC has no head parts or on the Settings-tab preview). -->
                <Button Content="Set Antler Head Parts…" Margin="0,6,0,0" HorizontalAlignment="Left" Padding="6,2"
                        Command="{Binding ToggleAntlerSelectorCommand}"
                        Visibility="{Binding IsAntlerSelectorAvailable, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"/>

                <Border Margin="0,6,0,0" Width="300" MaxHeight="380"
                        Background="#E0202020" CornerRadius="4" Padding="8"
                        Visibility="{Binding ShowAntlerSelector, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Antler head parts" Foreground="White"
                                   FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="#CCCCCC" FontSize="11"
                                   Margin="0,0,0,6"
                                   Text="Hover a head part or shape to highlight it in the preview. Check a shape to strip it from the output; check a whole head part to remove all of its shapes. This mod's Antler Handling Mode must be Remove for the removal to apply."/>
                        <ListBox ItemsSource="{Binding AntlerHeadPartCandidates}" Background="Transparent"
                                 BorderThickness="0" MaxHeight="300"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical">
                                        <!-- Parent head-part row: check = remove the WHOLE head
                                             part (record + every baked shape). Hover highlights the
                                             whole head part. Tri-state for display: indeterminate
                                             when only some ExtraParts below are stripped. -->
                                        <Border Background="Transparent" Padding="2,1"
                                                MouseEnter="AntlerCandidate_MouseEnter"
                                                MouseLeave="AntlerCandidate_MouseLeave">
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                          IsThreeState="False"
                                                          IsEnabled="{Binding CanToggle}" VerticalAlignment="Center"
                                                          ToolTip="Remove the entire head part (its record reference and all baked shapes)."/>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="White"
                                                           Margin="6,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding TypeLabel}" Foreground="#999999" FontSize="10"
                                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="(auto)" Foreground="#66CCFF" FontSize="10"
                                                           Margin="6,0,0,0" VerticalAlignment="Center"
                                                           ToolTip="Keyword-detected antler — always removed when the mode is Remove."
                                                           Visibility="{Binding IsAutoDetected, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- ExtraPart child rows (only when the head part has any).
                                             Each strips one baked ExtraPart shape (and removes it
                                             from the record); hover highlights just that shape.
                                             Disabled while the whole head part is being removed. -->
                                        <ItemsControl ItemsSource="{Binding ExtraShapes}" Margin="20,0,0,0"
                                                      Visibility="{Binding HasExtras, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="Transparent" Padding="2,1"
                                                            MouseEnter="AntlerCandidate_MouseEnter"
                                                            MouseLeave="AntlerCandidate_MouseLeave">
                                                        <StackPanel Orientation="Horizontal">
                                                            <CheckBox IsChecked="{Binding IsDesignated, Mode=TwoWay}"
                                                                      IsEnabled="{Binding DataContext.ExtrasEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                      VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding DisplayName}" Foreground="#DDDDDD"
                                                                       Margin="6,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="(auto)" Foreground="#66CCFF" FontSize="10"
                                                                       Margin="6,0,0,0" VerticalAlignment="Center"
                                                                       ToolTip="Keyword-detected antler — always removed when the mode is Remove."
                                                                       Visibility="{Binding IsAutoDetected, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </StackPanel>

            <!-- Missing-asset warning (attire/headgear mesh-override failures)
                 and the informational stale-physics-config notice, stacked so
                 both badges can show at once. The missing-asset badge mirrors
                 the mugshot tile's missing-asset icon pattern. -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6">
                <Border HorizontalAlignment="Right"
                        Background="#C0703000" CornerRadius="4" Padding="6,3"
                        ToolTip="{Binding MissingAssetNotificationText}"
                        Visibility="{Binding HasMissingAssets, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                    <TextBlock Text="⚠ Some attire meshes couldn't render" Foreground="White"
                               FontWeight="SemiBold"/>
                </Border>
                <!-- Stale physics config: the mod links an SMP/HDT xml that
                     doesn't exist. Render is correct, so this is informational
                     (stamped under a staleness-neutral metadata key; never
                     re-stales a mugshot). -->
                <Border HorizontalAlignment="Right" Margin="0,4,0,0"
                        Background="#C0305870" CornerRadius="4" Padding="6,3"
                        ToolTip="{Binding PhysicsConfigNoticeText}"
                        Visibility="{Binding HasPhysicsConfigNotice, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/NPC Plugin Chooser 2;component/Resources/Missing Outfit Assets.png"
                               Height="16" Margin="0,0,4,0"/>
                        <TextBlock Text="An attire mesh has a broken physics link" Foreground="White"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <!-- Antler removal: the mod's Antler Handling Mode is Remove and
                     this NPC carries an antler the patch strips (outfit / worn
                     armor / FaceGen head part). The preview hides it to match the
                     patched output; informational only. -->
                <Border HorizontalAlignment="Right" Margin="0,4,0,0"
                        Background="#C0305870" CornerRadius="4" Padding="6,3"
                        ToolTip="{Binding AntlerRemovalNoticeText}"
                        Visibility="{Binding HasAntlerRemovalNotice, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                    <TextBlock Text="Antlers removed (hidden to match output)" Foreground="White"
                               FontWeight="SemiBold"/>
                </Border>
            </StackPanel>

            <!-- Outfit-conflict warning: "Include Outfit" is overridden at
                 runtime by a SkyPatcher/SPID config, or NPC2's own SkyPatcher
                 ini entry is not conflict-winning. The banner text names the
                 winning config so the user knows why the preview wears what
                 it wears. -->
            <Border HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="6"
                    Background="#C0703000" CornerRadius="4" Padding="6,3"
                    Visibility="{Binding HasOutfitNotice, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding OutfitNoticeText}" Foreground="White"
                           FontWeight="SemiBold" TextWrapping="Wrap"/>
            </Border>
        </Grid>

        <!-- Status -->
        <Border Grid.Row="4" Padding="6,4" BorderBrush="Gray" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" Opacity="0.8" TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</UserControl>
