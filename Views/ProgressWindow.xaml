<Window x:Class="NPC_Plugin_Chooser_2.Views.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NPC_Plugin_Chooser_2.View_Models"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:VM_ProgressWindow}"
        Title="{Binding Title}"
        Height="220" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Topmost="True"
        ShowInTaskbar="False"
        Style="{StaticResource ThemedWindowStyle}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status Message -->
        <TextBlock Grid.Row="0"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,4"
                   FontSize="12"/>

        <!-- Optional sub-item line (current Mod — NPC, etc.). Hidden when
             the bound string is empty so older callers that don't set it
             keep the original two-row layout. -->
        <TextBlock Grid.Row="1"
                   Text="{Binding CurrentSubItem}"
                   TextWrapping="NoWrap"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,8"
                   FontSize="11"
                   FontStyle="Italic"
                   Opacity="0.85">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentSubItem}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="2"
                     Height="25"
                     Minimum="0"
                     Maximum="{Binding ProgressMaximum}"
                     Value="{Binding ProgressValue}"
                     IsIndeterminate="{Binding IsIndeterminate}"
                     Margin="0,0,0,8"/>

        <!-- Progress Text + ETA on the same row, ETA right-aligned. -->
        <Grid Grid.Row="3" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" HorizontalAlignment="Center">
                <Run Text="{Binding ProgressValue, StringFormat='{}{0:F0}', Mode=OneWay}"/>
                <Run Text=" / "/>
                <Run Text="{Binding ProgressMaximum, StringFormat='{}{0:F0}', Mode=OneWay}"/>
            </TextBlock>

            <TextBlock Grid.Column="1"
                       Text="{Binding EtaText}"
                       Margin="12,0,0,0"
                       Opacity="0.85"
                       FontSize="11">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EtaText}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Cancel/Abort Button -->
        <Button Grid.Row="4"
                Content="{Binding CancelButtonText}"
                Command="{Binding CancelCommand}"
                IsEnabled="{Binding CanCancel}"
                Width="100"
                Height="30"
                HorizontalAlignment="Center"/>
    </Grid>
</Window>
